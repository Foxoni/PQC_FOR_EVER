# Copier ce fichier en .env et adapter les valeurs AVANT de lancer docker compose.
# .env n'est jamais commite (voir .gitignore).

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=changeme_strong_password
INFLUX_ORG=pqc
INFLUX_BUCKET=pqc_bench
INFLUX_TOKEN=changeme_long_random_token

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# ── Push depuis le serveur / VMs (meme token que ci-dessus) ──────────────────
# A exporter dans l'environnement shell :
#   export INFLUX_URL=http://<IP_SERVEUR>:8086
#   export INFLUX_TOKEN=<valeur INFLUX_TOKEN ci-dessus>
#   export INFLUX_ORG=pqc
#   export INFLUX_BUCKET=pqc_bench
