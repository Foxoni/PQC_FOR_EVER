  "panels": [

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Connectivité",
      "type": "row"
    },

    {
      "datasource": {"type": "influxdb", "uid": "influxdb-pqc"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "green", "mode": "fixed"},
          "mappings": [
            {
              "type": "special",
              "options": {"match": "null", "result": {"color": "red", "index": 0, "text": "non connecté"}}
            },
            {
              "type": "special",
              "options": {"match": "empty", "result": {"color": "red", "index": 1, "text": "non connecté"}}
            }
          ],
          "noValue": "non connecté",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["count"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "influxdb-pqc"},
          "query": "from(bucket: \"pqc_bench\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"vm_heartbeat\" and r._field == \"state_code\")\n  |> group(columns: [\"host\"])\n  |> last()\n  |> group()",
          "refId": "A"
        }
      ],
      "title": "VMs connectées",
      "type": "stat"
    },

    {
      "datasource": {"type": "influxdb", "uid": "influxdb-pqc"},
      "fieldConfig": {
