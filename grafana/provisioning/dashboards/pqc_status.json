        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "influxdb-pqc"},
          "query": "from(bucket: \"pqc_bench\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"vm_heartbeat\" and r._field == \"state_code\")\n  |> group(columns: [\"host\"])\n  |> last()\n  |> filter(fn: (r) => r._value == 2)\n  |> group()\n  |> count()",
          "refId": "A"
        }
      ],
      "title": "VMs armées",
      "type": "stat"
    },

    {
      "datasource": {"type": "influxdb", "uid": "influxdb-pqc"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "yellow", "value": 1},
