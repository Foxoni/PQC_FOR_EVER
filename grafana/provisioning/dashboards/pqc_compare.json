        "xField": "run_id"
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-PQC}" },
          "query": "from(bucket: \"pqc_bench\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r._measurement == \"handshake\" and (r._field == \"hs_avg\" or r._field == \"hs_p99\"))\n  |> group(columns: [\"run_id\", \"_field\"])\n  |> mean()\n  |> group()",
